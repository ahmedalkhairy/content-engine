APP_ENV=production
APP_SECRET_KEY=change-me-to-a-random-secret-key
DATABASE_URL=sqlite:///./storage/infra_content.db

# Dedicated port on shared servers (web listens on APP_PORT)
APP_PORT=8010
APP_BIND=0.0.0.0

# Public URL (Telegram links + cookies). Examples:
#   http://YOUR_SERVER_IP:8010
#   https://content.example.com  (if nginx/Caddy proxies to APP_PORT)
DOMAIN=content.example.com
APP_PUBLIC_URL=http://YOUR_SERVER_IP:8010
SESSION_COOKIE_SECURE=false

# LLM: openai | gemini | mock
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Image: mock | openai | gemini
IMAGE_PROVIDER=mock
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

LINKEDIN_MODE=manual

# Telegram: bot token from @BotFather; chat ID = numeric (run: python -m app telegram-info)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

AUTO_PUBLISH_ENABLED=false
DEFAULT_TIMEZONE=Asia/Jerusalem
