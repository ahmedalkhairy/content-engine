[Unit]
Description=InfraPilot Content Engine Scheduler Worker
After=network.target infra-content-web.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/infra-content-engine
Environment=PATH=/opt/infra-content-engine/venv/bin
ExecStart=/opt/infra-content-engine/venv/bin/python -m app worker --interval 60
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
